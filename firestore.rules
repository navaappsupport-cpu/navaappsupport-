rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Messages: authenticated users can read/write in conversations they're part of
    match /messages/{chatId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Friend requests: authenticated users can read/write
    match /friendRequests/{docId} {
      allow read, write: if request.auth != null;
    }

    // Friends: authenticated users can read/write
    match /friends/{docId} {
      allow read, write: if request.auth != null;
    }

    // Blocks: authenticated users can create/read their own blocks
    match /blocks/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.blockedBy == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.blockedBy == request.auth.uid;
    }

    // Reports: authenticated users can create and read their own reports
    match /reports/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.reportedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // Chat settings: users can manage only their own settings documents
    match /chatSettings/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Calls: authenticated users can read/write calls and ICE candidates
    match /calls/{docId} {
      allow read, write: if request.auth != null;
    }
    match /calls/{docId}/{subcol}/{candidateId} {
      allow read, write: if request.auth != null;
    }
  }
}
