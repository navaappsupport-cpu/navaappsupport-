rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function friendDocId(userId, friendId) {
      return userId + '_' + friendId;
    }

    function areFriends(userA, userB) {
      return firestore.exists(/databases/(default)/documents/friends/$(friendDocId(userA, userB))) &&
        firestore.exists(/databases/(default)/documents/friends/$(friendDocId(userB, userA)));
    }

    match /profilePhotos/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /statuses/{userId}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == userId || areFriends(userId, request.auth.uid));
      allow write: if signedIn()
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('(image|video)/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}